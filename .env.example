NEXT_PUBLIC_API_URL=http://localhost:8080
# Production: the API must list this dashboard origin in ALLOWED_ORIGINS (e.g. https://www.diet-agent.com) or browser calls to /me/* will fail CORS.

# MCP client rollout (dashboard copy + /connect tabs). Flip CHATGPT to `active` at Wave 2 — no structural code changes.
NEXT_PUBLIC_CLAUDE_STATUS=active
NEXT_PUBLIC_CHATGPT_STATUS=coming_soon
# Approximate coach replies/day when no BYOK (browser-enforced fallback; overrides default 20)
# NEXT_PUBLIC_HOSTED_CHAT_DAILY_MESSAGES=20
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Prefer publishable key (sb_publishable_…); legacy anon JWT still supported as fallback
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: HS256 dev token when API runs with JWT_SECRET only (no SUPABASE_URL on API)
# NEXT_PUBLIC_DEV_JWT=
